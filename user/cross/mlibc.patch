diff --color -ru --new-file '--exclude=subprojects' mlibc-6.3.1/mlibc-bayos.txt mlibc-bayos/mlibc-bayos.txt
--- mlibc-6.3.1/mlibc-bayos.txt	1970-01-01 01:00:00.000000000 +0100
+++ mlibc-bayos/mlibc-bayos.txt	2026-04-23 21:25:32.788007379 +0200
@@ -0,0 +1,16 @@
+[host_machine]
+system = 'bayos'
+cpu_family = 'x86_64'
+cpu = 'x86_64'
+endian = 'little'
+[binaries]
+c = 'x86_64-bayos-gcc'
+cpp = 'x86_64-bayos-g++'
+ar = 'x86_64-bayos-ar'
+strip = 'x86_64-bayos-strip'
+ld = 'x86_64-bayos-ld'
+[built-in options]
+c_args = ['-nostdlib', '-nostartfiles']
+cpp_args = ['-nostdlib', '-nostartfiles']
+c_link_args = ['-nostdlib', '-nostartfiles']
+cpp_link_args = ['-nostdlib', '-nostartfiles']
diff --color -ru --new-file '--exclude=subprojects' mlibc-6.3.1/sysdeps/bayos/crt1.S mlibc-bayos/sysdeps/bayos/crt1.S
--- mlibc-6.3.1/sysdeps/bayos/crt1.S	1970-01-01 01:00:00.000000000 +0100
+++ mlibc-bayos/sysdeps/bayos/crt1.S	2026-04-27 20:08:42.000932379 +0200
@@ -0,0 +1,8 @@
+.section .text
+.global _start
+_start:
+	mov %rsp, %rdi
+	mov $main, %rsi
+	call __mlibc_entry
+
+.section .note.GNU-stack,"",%progbits
diff --color -ru --new-file '--exclude=subprojects' mlibc-6.3.1/sysdeps/bayos/entry.cpp mlibc-bayos/sysdeps/bayos/entry.cpp
--- mlibc-6.3.1/sysdeps/bayos/entry.cpp	1970-01-01 01:00:00.000000000 +0100
+++ mlibc-bayos/sysdeps/bayos/entry.cpp	2026-04-28 17:30:01.191420430 +0200
@@ -0,0 +1,14 @@
+#include <stdint.h>
+#include <stdlib.h>
+#include <mlibc/elf/startup.h>
+
+extern "C" void __dlapi_enter(uintptr_t *);
+
+extern char **environ;
+
+extern "C" void __mlibc_entry(uintptr_t *entry_stack, int (*main_fn)(int argc, char *argv[], char *env[])) {
+    __dlapi_enter(entry_stack);
+
+    auto result = main_fn(0, nullptr, nullptr);
+    exit(result);
+}
