+		input: 'crt1.S',
+		output: 'crt1.o',
+		install: true,
+		install_dir: get_option('libdir')
+	)
+endif
+
+rtld_sources += files(
+	'sysdeps.cpp',
+	'syscall.cpp',
+)
+rtld_include_dirs += include_directories('include')
+
+libc_sources += files(
